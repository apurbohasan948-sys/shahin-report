rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-All Default Safety Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.email.toLowerCase() == "apurbohasan948@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email.toLowerCase()))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.\\@]+$');
    }

    // Admins Collection Rules
    match /admins/{email} {
      allow read: if isEmailVerified();
      allow write: if isAdmin() && isValidId(email);
    }

    // Reports Collection Rules
    match /reports/{reportId} {
      allow read: if isEmailVerified();
      
      allow create: if isEmailVerified() && isValidId(reportId) && (
        isAdmin() || 
        (request.resource.data.patient.agency == "SHAHIN/AF-1")
      );

      allow update: if isEmailVerified() && isValidId(reportId) && (
        isAdmin() ||
        (
          resource.data.patient.agency == "SHAHIN/AF-1" &&
          request.resource.data.patient.agency == "SHAHIN/AF-1" &&
          resource.data.approvalStatus != "Approved" &&
          (request.resource.data.approvalStatus == "Draft" || request.resource.data.approvalStatus == "Pending Approval")
        )
      );

      allow delete: if isAdmin();
    }
  }
}
